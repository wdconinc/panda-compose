# PanDA Compose — environment variable template
# Copy to .env and fill in secrets before running `docker compose up`.
# Variable names mirror those used in panda-k8s/secrets/templates/.

# ──────────────────────────────────────────────
# PostgreSQL (PanDA server + JEDI)
# ──────────────────────────────────────────────
PANDA_DB_BACKEND=postgres
PANDA_DB_HOST=postgres
PANDA_DB_PORT=5432
PANDA_DB_USER=panda
PANDA_DB_PASSWORD=panda_secret
PANDA_DB_NAME=panda_db

# Schema names (must match the values baked into the panda-database image init scripts)
PANDA_DB_SCHEMAPANDA=DOMA_PANDA
PANDA_DB_SCHEMAMETA=DOMA_PANDAMETA
PANDA_DB_SCHEMAPANDAARCH=DOMA_PANDAARCH
PANDA_DB_SCHEMAJEDI=DOMA_PANDA
PANDA_DB_SCHEMADEFT=DOMA_DEFT

# ──────────────────────────────────────────────
# ActiveMQ
# ──────────────────────────────────────────────
PANDA_ACTIVEMQ_LIST=activemq:61613
PANDA_ACTIVEMQ_PASSWD_panda=panda_mq_secret
PANDA_ACTIVEMQ_PASSWD_jedi=jedi_mq_secret

# ──────────────────────────────────────────────
# PanDA server
# ──────────────────────────────────────────────
# Internal service URL used by Harvester and panda-client.
PANDA_URL=http://panda-server:80/server/panda
PANDA_URL_SSL=https://panda-server:443/server/panda
PANDA_VERIFY_HOST=off
PANDA_BEHIND_REAL_LB=1

# Authentication: set to "oidc" for token-based or leave "None" for x509/no-auth dev mode
PANDA_AUTH=None

# ──────────────────────────────────────────────
# MariaDB (Harvester)
# ──────────────────────────────────────────────
HARVESTER_DB_USER=harvester
HARVESTER_DB_PASSWORD=harvester_secret
HARVESTER_DB_NAME=harvester_db

# ──────────────────────────────────────────────
# Harvester
# ──────────────────────────────────────────────
HARVESTER_EXPERIMENT=wlcg

# ──────────────────────────────────────────────
# Optional HTTP/S proxy (leave blank if not needed)
# ──────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
