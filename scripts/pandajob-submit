#!/usr/bin/env python3
"""
pandajob-submit — submit a shell script as a PanDA job and print the job ID.

Usage:
    pandajob-submit --site SITE --script SCRIPT [--name NAME]

Environment:
    PANDA_URL        PanDA server URL (default: http://localhost:25080/server/panda)
    PANDA_URL_SSL    PanDA server HTTPS URL

Exit codes:
    0  success — job ID is printed to stdout
    1  submission failure
"""
import argparse
import json
import os
import sys

# Allow override via environment for the dev stack.
os.environ.setdefault("PANDA_URL", "http://localhost:25080/server/panda")
os.environ.setdefault("PANDA_URL_SSL", os.environ["PANDA_URL"])
# Suppress "No valid grid proxy certificate found" noise from pandaclient.
os.environ.setdefault("X509_USER_PROXY", "/dev/null")

try:
    from pandaclient import Client, JobSpec
except ImportError as exc:
    print(f"ERROR: panda-client is not installed: {exc}", file=sys.stderr)
    sys.exit(1)


def parse_args():
    p = argparse.ArgumentParser(description="Submit a job script to PanDA")
    p.add_argument("--site", default="PANDA_COMPOSE_LOCAL", help="PanDA compute site (queue name)")
    group = p.add_mutually_exclusive_group(required=True)
    group.add_argument("--script", help="Path to a bash script to execute (must be accessible inside the worker container)")
    group.add_argument("--transformation", help="Executable to run directly (e.g. /bin/echo)")
    p.add_argument("--params", default="", help="Job parameters string (used with --transformation)")
    p.add_argument("--container", default=None, metavar="IMAGE",
                   help="Container image to run the job in (e.g. python:3.12-alpine). "
                        "Sets job.container_name, mirroring PanDA's per-job container field. "
                        "The Harvester DockerSubmitter reads this and falls back to the "
                        "queue-level default when not specified.")
    p.add_argument("--name", default="panda-compose-job", help="Job name")
    p.add_argument("--cores", type=int, default=1, help="Number of CPU cores")
    p.add_argument("--memory", type=int, default=2000, help="Memory in MB")
    p.add_argument("--walltime", type=int, default=3600, help="Walltime in seconds")
    return p.parse_args()


def main():
    args = parse_args()

    if args.script:
        script_path = os.path.abspath(args.script)
        if not os.path.isfile(script_path):
            print(f"ERROR: script not found: {script_path}", file=sys.stderr)
            sys.exit(1)
        transformation = "/bin/bash"
        job_params = script_path
    else:
        transformation = args.transformation
        job_params = args.params

    job = JobSpec.JobSpec()
    job.jobName = args.name
    job.computingSite = args.site
    job.transformation = transformation
    job.jobParameters = job_params
    if args.container:
        job.container_name = args.container
    job.prodSourceLabel = "test"
    job.processingType = "panda-compose"
    job.maxCpuCount = args.cores
    job.minRamCount = args.memory
    job.maxDiskCount = 1000
    job.ipConnectivity = "yes"
    # jobDefinitionID has a NOT NULL constraint in the PanDA schema.
    job.jobDefinitionID = 1

    status, job_ids = Client.submitJobs([job], verbose=False)
    if status != 0 or not job_ids:
        print(f"ERROR: submitJobs failed with status {status}", file=sys.stderr)
        sys.exit(1)

    # submitJobs returns a list of [pandaID, serialNo, jobName] per job.
    first = job_ids[0]
    if isinstance(first, (list, tuple)):
        job_id = first[0]
    else:
        job_id = first
    if job_id is None or str(job_id) == "NULL" or int(job_id) < 0:
        print(f"ERROR: invalid PanDA job ID returned: {job_id}", file=sys.stderr)
        sys.exit(1)

    print(int(job_id))


if __name__ == "__main__":
    main()
